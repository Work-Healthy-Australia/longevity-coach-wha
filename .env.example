# ============================================================================
# Longevity Coach — environment variables
# Copy to .env.local and fill in. Never commit .env* files.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# From Supabase dashboard: Project Settings -> API Keys
# New key format (sb_publishable_*, sb_secret_*) — the legacy anon /
# service_role JWTs are being deprecated for new projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only. Used for service-role operations (risk engine writes,
# webhooks). NEVER expose to the browser.
SUPABASE_SECRET_KEY=

# --- Site -------------------------------------------------------------------
# Public site URL — used for email links, OAuth callbacks, etc.
# Local: http://localhost:3000
# Preview: set per deployment via Vercel
# Prod: https://longevity-coach.io
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Anthropic (Claude API) -------------------------------------------------
# Used by lib/ai/* for risk narratives + supplement generation
ANTHROPIC_API_KEY=

# --- Resend (transactional email) ------------------------------------------
# Used for welcome email + onboarding drip
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Stripe ----------------------------------------------------------------
# Test keys for local dev; live keys in Vercel for prod.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs from the Stripe dashboard — one per plan tier.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
