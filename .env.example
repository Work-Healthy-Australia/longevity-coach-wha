# ============================================================================
# Longevity Coach — environment variables
# Copy to .env.local and fill in. Never commit .env* files.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# From Supabase dashboard: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used for service-role operations (risk engine writes, webhooks).
# NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Site -------------------------------------------------------------------
# Public site URL — used for email links, OAuth callbacks, etc.
# Local: http://localhost:3000
# Preview: set per deployment via Vercel
# Prod: https://longevity-coach.io
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Anthropic (Claude API) -------------------------------------------------
# Used by lib/ai/* for risk narratives + supplement generation
ANTHROPIC_API_KEY=

# --- Resend (transactional email) ------------------------------------------
# Used for welcome email + onboarding drip
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Stripe (Day 1+, wire up later) ----------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
