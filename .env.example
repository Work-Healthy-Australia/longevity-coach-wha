# ─────────────────────────────────────────────────────────────────────────────
# Longevity Coach — environment variables
#
# Copy to .env.local for local development. All secrets stay server-side
# unless prefixed NEXT_PUBLIC_. Missing optional keys must silently no-op
# (per .claude/rules/security.md) — never hard-error in preview environments.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# Use the new key naming (sb_publishable_* / sb_secret_*). Do NOT use the
# legacy ANON_KEY / SERVICE_ROLE_KEY env names.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ── Site ────────────────────────────────────────────────────────────────────
# Used for absolute URLs (auth callbacks, emails, Stripe redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Anthropic (Claude API) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenRouter (embeddings via perplexity/pplx-embed) ───────────────────────
OPENROUTER_API_KEY=

# ── Resend (transactional email) ────────────────────────────────────────────
# Welcome email silently no-ops if RESEND_API_KEY is absent — intentional.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Stripe ──────────────────────────────────────────────────────────────────
# STRIPE_WEBHOOK_SECRET is the signing secret from the dashboard webhook
# configuration, not the API key. Webhook route reads raw body for signature
# verification — do not add body parsers in front of /api/stripe/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Optional: amounts in cents for display fallback when Stripe lookup fails.
STRIPE_PRICE_MONTHLY_AMOUNT=
STRIPE_PRICE_ANNUAL_AMOUNT=

# ── Sentry ──────────────────────────────────────────────────────────────────
# DSN is safe to expose; auth token is build-time only for source maps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Pipeline / cron ─────────────────────────────────────────────────────────
# Shared secret for protecting cron-triggered pipeline routes.
PIPELINE_SECRET=
CRON_SECRET=

# ── Cost monitoring ─────────────────────────────────────────────────────────
# Daily Anthropic API spend threshold in USD. /api/cron/cost-rollup fires a
# row into agent_cost_alerts and emails admins when yesterday's spend exceeds
# this. Default 50 if unset.
COST_DAILY_BUDGET_USD=50

# ── Right-to-erasure ────────────────────────────────────────────────────────
# Set ENABLE_HARD_DELETE=1 to allow the erasure worker to perform hard
# deletes. Default (unset) keeps soft-delete-only behaviour.
ENABLE_HARD_DELETE=
